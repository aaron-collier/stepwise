<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h4 class="mb-0">Edit Profile</h4>
      </div>
      <div class="card-body">
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @user, url: profile_path, method: :patch do |f| %>
          <div class="mb-3">
            <%= f.label :first_name, class: "form-label" %>
            <%= f.text_field :first_name,
                  class: "form-control #{'is-invalid' if @user.errors[:first_name].any?}" %>
            <% if @user.errors[:first_name].any? %>
              <div class="invalid-feedback">
                <%= @user.errors[:first_name].first %>
              </div>
            <% end %>
          </div>

          <div class="mb-3">
            <%= f.label :last_name, class: "form-label" %>
            <%= f.text_field :last_name,
                  class: "form-control #{'is-invalid' if @user.errors[:last_name].any?}" %>
            <% if @user.errors[:last_name].any? %>
              <div class="invalid-feedback">
                <%= @user.errors[:last_name].first %>
              </div>
            <% end %>
          </div>

          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email,
                  class: "form-control #{'is-invalid' if @user.errors[:email].any?}" %>
            <% if @user.errors[:email].any? %>
              <div class="invalid-feedback">
                <%= @user.errors[:email].first %>
              </div>
            <% end %>
          </div>

          <div class="d-flex gap-2 justify-content-end">
            <%= link_to "Cancel", profile_path, class: "btn btn-outline-secondary" %>
            <%= f.submit "Save", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
